# Database
# 16_BUS_SUPABASE_URL=postgresql://user:password@host:port/dbname
16_BUS_SUPABASE_URL=sqlite:///./16_bus.db

# Redis
REDIS_DSN=redis://localhost:6379/0

# Security
JWT_SECRET_KEY=generate-something-secure-here
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRY_MINUTES=30

# Application
ENVIRONMENT=development
BOOKING_HOLD_MINUTES=5
